# ── Google Gemini ──
# Get from: https://aistudio.google.com/apikey
# Scope: "Generative Language API" — no special scopes, just create an API key
# Used by: /api/analyze (vitals analysis), /api/generate-synthetic (training data)
GEMINI_API_KEY=your_gemini_api_key
# Model ID — defaults to gemini-2.5-flash-preview-05-20 if not set
# Browse models at https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# ── ElevenLabs ──
# Get from: https://elevenlabs.io/app/settings/api-keys → "Create API Key"
# Scope: "Text to Speech" — default key has this, no special permissions needed
# Used by: /api/speak (voice read-aloud)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Voice ID — default is "Sarah". Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── Solana ──
# Generate a devnet keypair: solana-keygen new --outfile ~/.config/solana/devnet.json
# Then fund it: solana airdrop 2 --url devnet
# Paste the JSON array from the keypair file here (e.g. [12,34,56,...])
# Scope: just a devnet wallet — no program authority needed, only sends memo txs
# Used by: /api/log-vitals (blockchain audit trail)
SOLANA_PRIVATE_KEY=[your_keypair_byte_array]

# ── Backblaze B2 ──
# Get from: https://secure.backblazeb2.com/app_keys.htm → "Add a New Application Key"
# Scope: needs "Read and Write" access to the target bucket only
#   - Key type: Application Key (not Master Key)
#   - Bucket: select your specific bucket
#   - Capabilities: listBuckets, listFiles, readFiles, writeFiles
# Used by: /api/store-vitals (persist vitals JSON)
B2_KEY_ID=your_backblaze_key_id
B2_APP_KEY=your_backblaze_app_key
B2_BUCKET_ID=your_bucket_id

# ── Presage / SmartSpectra ──
# Get from: https://physiology.presagetech.com
# Used by: /api/presage/* via a separate Presage bridge service
# Notes:
# - Public Presage docs currently expose native SDKs, not a browser/WASM SDK.
# - In this app, the backend forwards webcam frames to your own bridge process/server.
PRESAGE_API_KEY=your_presage_api_key
# Base URL for your SmartSpectra bridge service, e.g. http://localhost:8787
PRESAGE_BRIDGE_URL=http://localhost:8787
# Optional request timeout for bridge calls
PRESAGE_TIMEOUT_MS=20000
# Optional local bridge mode if you run the bundled bridge server
# "mock" works end-to-end today; swap to your native bridge mode later
PRESAGE_BRIDGE_MODE=mock

# ── Server ──
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@vitalsight.tech
